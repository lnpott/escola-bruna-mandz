+:root {
+    color-scheme: dark;
+    --bg: #0b0b0c;
+    --panel: #18181b;
+    --muted: #a1a1aa;
+    --brand: #ef4444;
+    --brand-dark: #991b1b;
+    --line: #27272a;
+}
+* { box-sizing: border-box; }
+body { margin: 0; font-family: Inter, system-ui, sans-serif; background: var(--bg); color: #fff; }
+.store-section { width: min(1120px, calc(100% - 32px)); margin: 0 auto; padding: 48px 0; }
+.store-title { font-size: clamp(2rem, 5vw, 3.5rem); margin: 0 0 8px; }
+.store-subtitle { color: var(--muted); margin: 0 0 28px; }
+.product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 18px; }
+.product-card { background: linear-gradient(145deg, #18181b, #0f0f11); border: 1px solid var(--line); border-radius: 24px; padding: 20px; box-shadow: 0 20px 50px rgba(0,0,0,.25); }
+.product-card img { width: 100%; height: 150px; object-fit: contain; background: #fff; border-radius: 18px; padding: 12px; }
+.product-card h3 { margin: 16px 0 8px; }
+.product-card p { color: var(--muted); }
+.product-price { color: #fff; font-size: 1.4rem; font-weight: 900; }
+.store-button, .product-card button { border: 0; border-radius: 999px; padding: 12px 18px; color: #fff; background: linear-gradient(135deg, var(--brand), var(--brand-dark)); font-weight: 800; cursor: pointer; }
+.store-button.secondary { background: #27272a; }
+.store-layout { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 24px; }
+.cart-panel { position: sticky; top: 24px; align-self: start; background: #111113; border: 1px solid var(--line); border-radius: 24px; padding: 20px; }
+.cart-line { display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid var(--line); padding: 10px 0; color: var(--muted); }
+.admin-toolbar { display: flex; gap: 12px; flex-wrap: wrap; margin: 16px 0 24px; }
+input, select { width: 100%; border: 1px solid var(--line); background: #09090b; color: #fff; border-radius: 12px; padding: 10px 12px; }
+@media (max-width: 860px) { .store-layout { grid-template-columns: 1fr; } .cart-panel { position: static; } }
