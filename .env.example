# ═══════════════════════════════════════════════════════════════════════════
# Variáveis de ambiente — Loja Oficial Bruna Mandz
#
# Este arquivo é só um EXEMPLO. Nunca suba um .env real (com valores
# preenchidos) para o GitHub — ele já está no .gitignore.
#
# Para rodar localmente: copie este arquivo para `.env` e preencha os valores.
# Para produção: configure cada uma destas variáveis no painel da Vercel em
#   Project Settings > Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Pegue em: https://www.mercadopago.com.br/developers > Suas integrações > Credenciais
# Use as credenciais de TESTE primeiro, depois troque para produção quando for ao ar.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# URL pública do seu site para o Mercado Pago notificar pagamentos (opcional,
# também pode ser configurado direto no painel do Mercado Pago em Webhooks)
MP_WEBHOOK_URL=https://seu-dominio.vercel.app/api/webhook

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Pegue em: Supabase > seu projeto > Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Painel administrativo ─────────────────────────────────────────────────────
# Senha simples para acessar /painel-x9k2f.html — escolha algo forte, não use
# uma senha que você já usa em outro lugar.
ADMIN_PASSWORD=
